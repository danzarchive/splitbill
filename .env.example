# ============================================
# SplitBill - Environment Variables
# ============================================

# --------------------------------------------
# REQUIRED - Database (Turso)
# --------------------------------------------
DATABASE_URL="libsql://your-db.turso.io"
DATABASE_AUTH_TOKEN="your-turso-auth-token"

# --------------------------------------------
# REQUIRED - Security
# --------------------------------------------
CRON_SECRET="random-secret-for-cleanup-api"

# --------------------------------------------
# OPTIONAL - App Configuration
# --------------------------------------------

# Public app URL for generating share links
# If not set, will use window.location.origin
NEXT_PUBLIC_APP_URL="https://bayarbill.vercel.app"

# Default currency for bill formatting
# Options: IDR, USD, SGD, etc
NEXT_PUBLIC_DEFAULT_CURRENCY="IDR"

# Auto-delete bills after X days of inactivity
# Default: 30 days
BILL_EXPIRY_DAYS="30"

# Default tax rate (PPN) percentage
# Default: 10%
DEFAULT_TAX_RATE="10"
